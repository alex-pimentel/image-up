MAX_UPLOAD_MB=8
MAX_INPUT_PX=1000
OUTPUT_QUALITY=95
OUTPUT_FORMAT=webp
DEFAULT_SCALE=2

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=imageup:
# CELERY_BROKER_URL and CELERY_RESULT_BACKEND default to REDIS_URL

# ML
USE_GPU=0
MODEL_NAME=RealESRGAN_x4plus
ENABLE_ML=1
FALLBACK_IF_UNAVAILABLE=1

# Storage
RESULT_TTL_SEC=3600